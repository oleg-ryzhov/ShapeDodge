<body onload="init()">

<div id="game-wrapper">
    <canvas id="gameCanvas"></canvas>

    <div id="overlay">
        <div id="main-menu">
            <div>
                <h1 class="title">ShapeDodge</h1>
                <p id="subtitle">VERSION 1.7.1</p>
            </div>
            
            <div class="button-group">
                <button id="start-btn" onclick="startGame()">START GAME</button>
            </div>

            <p class="copyright">&copy; 2026 Oleg Ryzhov Industries</p>
        </div>

        <div id="pause-menu" class="hidden">
            <div>
                <h1 class="title">PAUSED</h1>
                <p class="subtitle">ShapeDodge 1.7.1</p>
            </div>
            
            <div class="button-group">
                <button id="resume-btn" onclick="resumeGame()">CONTINUE</button>
                <button id="restart-btn" onclick="startGame()">RESTART</button>
                <button id="main-menu-btn" onclick="quitToMenu()">MAIN MENU</button>
            </div>
        </div>

        <div id="game-over-menu" class="hidden">
            <div class="stats-side">
                <h1 class="title">GAME OVER!</h1>
                <p class="subtitle">Score: <span id="total-score">0</span></p>
                <p class="subtitle">Waves survived: <span id="waves-survived">0</span></p>
            </div>
            
            <div class="button-group">
                <button id="retry-btn" onclick="startGame()">RETRY</button>
                <button id="main-menu-btn" onclick="quitToMenu()">MAIN MENU</button>
            </div>
        </div>
        
    </div>
</div>
