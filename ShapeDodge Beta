<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<style>
    html, body {
        margin: 0;
        padding: 0;
        overflow: hidden;
    }
    canvas {
        display: block;
        background-color: #f1f1f1;
    }
</style>
</head>
<body onload="startGame()">
<script>

// ======== TICK ENGINE VARS ========
const tickLength = 20;        // 50 ticks per second
let frameAccumulator = 0;     // Store leftover time after every tick
let lastTimestamp = 0;        // Store time of previous frame

/* ============================	
          PLAYER CLASS
   ============================ */
class Player {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.width = 80;
        this.height = 80;
        this.speedX = 0;
        this.speedY = 0;
        this.speed = 8;
        this.maxHP = 200;
        this.hp = this.maxHP;

        this.lastDamageTime = 0; 
        this.damageCooldown = 50; // 50 tps

        this.lastShotTime = 0; 
        this.shotCooldown = 20;   // 0.4 seconds
        
        // Keep track of last time cooldown events occured
        this.damageTickCounter = -150; // 3 seconds immortality at start 
        this.shotTickCounter = 20;
    }
	
    // ======== CALCULATIONS ========
    update() {
        this.x += this.speedX;
        this.y += this.speedY;

        // Keep player inside canvas
        this.x = Math.max(0, Math.min(this.x, gameArea.canvas.width - this.width));
        this.y = Math.max(0, Math.min(this.y, gameArea.canvas.height - this.height));

        this.damageTickCounter++;
        this.shotTickCounter++;
    }

    // ======== VISUALS ========
    draw() {
        const ctx = gameArea.context;

        // Draw Player Icon
        ctx.fillStyle = "red";
        ctx.fillRect(this.x, this.y, this.width, this.height);

        // Draw Health Bar UI
        const barWidth = 600;
        const barHeight = 30;
        const barX = (gameArea.canvas.width - barWidth) / 2;
        const barY = gameArea.canvas.height - barHeight - 10;

        ctx.fillStyle = "black";
        ctx.fillRect(barX, barY, barWidth, barHeight);

        ctx.fillStyle = "red";
        ctx.fillRect(barX, barY, barWidth * (this.hp / this.maxHP), barHeight);

        ctx.fillStyle = "white";
        ctx.font = "16px Arial";
        ctx.textAlign = "center";
        ctx.fillText(Math.ceil(this.hp) + " / " + this.maxHP, barX + barWidth / 2, barY + barHeight - 5);
    }
	
    // ======== DAMAGE LOGIC ========
    takeDamage(amount) {
        if (this.damageTickCounter >= this.damageCooldown) {
            this.hp = Math.max(0, this.hp - amount);
            this.damageTickCounter = 0;
        }
    }
    
    // ======== SHOOTING LOGIC ========
    shootLeft() {
        if (this.shotTickCounter >= this.shotCooldown) {
            bulletsObj.spawnBullet(this.x, this.y + (this.height / 2), -1, 0)
            this.shotTickCounter = 0
        }
    } shootRight() {
        if (this.shotTickCounter >= this.shotCooldown) {
            bulletsObj.spawnBullet(this.x + this.width, this.y + (this.height / 2), 1, 0)
            this.shotTickCounter = 0
        }
    } shootUp() {
        if (this.shotTickCounter >= this.shotCooldown) {
            bulletsObj.spawnBullet(this.x + (this.width / 2), this.y, 0, -1)
            this.shotTickCounter = 0
        }
    } shootDown() {
        if (this.shotTickCounter >= this.shotCooldown) {
            bulletsObj.spawnBullet(this.x + (this.width / 2), this.y + this.height, 0, 1)
            this.shotTickCounter = 0
        }
    }
}

/* ============================
          ENEMIES CLASS
   ============================ */
class Enemies {
    constructor() {
        this.types = {
            gary: { width:80, height:80, speed:5, max_hp:25, hp:25, damage:35, color:"blue", cost:15, special:null, track_player:false },
            fast:  { width:50, height:50, speed:8, max_hp:10, hp:10, damage:15, color:"yellow", cost:10, special:null, track_player:false },
            tank:  { width:150, height: 150, speed:3, max_hp:100, hp:100, damage:60, color:"purple", cost:50, special:null, track_player: false },
            tiny:  { width:25, height:25, speed:4, max_hp:5, hp:5, damage:10, color:"lime", cost:5, special:null, track_player: false },
            snail: { width:15, height:15, speed:1.5, max_hp:1000, hp:1000, damage:1, color:"black", cost:500, special:'one_hp', track_player:true }
        };
        this.components = [];
    }

    spawnEnemy(type) {
        const side = Math.random() < 0.5 ? 'left' : 'right'; // randomize side
        // offset reduced to just outside the edge so they "fly in" immediately
        let x = (side === 'left') ? -type.width : gameArea.canvas.width; // randomize x
        let y = Math.random() * (gameArea.canvas.height - type.height); // randomize y

        const centerX = gameArea.canvas.width / 2;
        const centerY = gameArea.canvas.height / 2;
        let dx = (side === 'left') ? 1 : -1;
        
        // Calculate vertical direction toward the horizontal center line
        let dy = (centerY - y) / (gameArea.canvas.height / 2);

        const enemy = {
            x, y,
            width: type.width, height: type.height,
            speed: type.speed,
            speedX: dx * type.speed,
            speedY: dy * (type.speed * 0.2),
            max_hp: type.max_hp,
            hp: type.max_hp,
            damage: type.damage,
            color: type.color, cost: type.cost,
            special: type.special,
            track_player: type.track_player,
        };
        this.components.push(enemy);
    }

    update() {
        this.components.forEach(e => {
            if (e.track_player) {
                // ======== PATHFINDING LOGIC (SNAIL) ========
                let dx = (playerObj.x + playerObj.width / 2) - (e.x + e.width / 2);
                let dy = (playerObj.y + playerObj.height / 2) - (e.y + e.height / 2);
                let angle = Math.atan2(dy, dx);
                
                e.x += Math.cos(angle) * e.speed;
                e.y += Math.sin(angle) * e.speed;
            } else {
                // ======== NORMAL ENEMIES (BOUNCE) ========
                e.x += e.speedX;
                e.y += e.speedY;

                // Only bounce if heading OUTSIDE the bounds
                if (e.x <= 0 && e.speedX < 0) {
                    e.x = 0; e.speedX = Math.abs(e.speedX); 
                }
                else if (e.x + e.width >= gameArea.canvas.width && e.speedX > 0) { 
                    e.x = gameArea.canvas.width - e.width; e.speedX = -Math.abs(e.speedX); 
                }

                if (e.y <= 0 && e.speedY < 0) { 
                    e.y = 0; e.speedY = Math.abs(e.speedY); 
                }
                else if (e.y + e.height >= gameArea.canvas.height && e.speedY > 0) { 
                    e.y = gameArea.canvas.height - e.height; e.speedY = -Math.abs(e.speedY); 
                }
            }
        });
    }
	// ======== RENDER VISUALS ========
    draw() {
    	// Draw Enemy
        const ctx = gameArea.context;
        this.components.forEach(e => {
            ctx.fillStyle = e.color;
            ctx.fillRect(e.x, e.y, e.width, e.height);
            
            // ======== HEALTH BAR ========
            
            // ------ Outline ------
            let barWidth = Math.max(64, e.width);
            let barHeight = Math.max(8, e.height / 10);
            
            let barX = (e.x + e.width / 2) - (barWidth / 2); // Centered above enemy
            let barY = e.y - 15; // 15px vertical offset
            
            ctx.fillStyle = "black";
            ctx.fillRect(barX, barY, barWidth, barHeight);
            
            // ------ Filler ------
            const outlineWeight = 2; // Weight of the black outline
            let fillerWidth = (e.hp / e.max_hp) * (barWidth - outlineWeight * 2)
            let fillerHeight = barHeight - outlineWeight * 2;
            
            let fillerX = barX + outlineWeight;
            let fillerY = barY + outlineWeight;
            
            ctx.fillStyle = "red";
            ctx.fillRect(fillerX, fillerY, fillerWidth, fillerHeight);
        });
    }
}

/* ============================
        WAVE MANAGER CLASS
   ============================ */
class WaveManager {
    constructor() {
        this.currentWave = 0; // Tracks the wave number
        this.spawnQueue = []; // The queue of all enemies waiting to enter the game
        this.spawnInterval = 40; 
        this.spawnTimer = 0;
        this.duration = 0; // Duration of the wave
        this.maxDuration = 3000; // Max duration of each wave (60 seconds)
        this.baseBudget = 30; // Budget for each wave
    }

    update() {
        // list of active enemies
        const activeEnemies = enemiesObj.components.filter(e => e.special !== 'one_hp').length;
        this.duration++;
	
        if (this.spawnQueue.length === 0) {
            if (activeEnemies === 0 || this.duration >= this.maxDuration) {
                // HAS to spawn if there are 0 enemies OR max wave duration was surpassed
                this.startNextWave();
            } else if (activeEnemies <= 2) {
                // 1% chance to start new wave (runs every tick)
                if (Math.floor(Math.random() * 100) == 1) {
                    this.startNextWave();
                }
            }
        }
		// Spawn enemies from the queue
        if (this.spawnQueue.length > 0) {
            this.spawnTimer++;
            if (this.spawnTimer >= this.spawnInterval) {
                let nextType = this.spawnQueue.shift();
                enemiesObj.spawnEnemy(nextType);
                this.spawnTimer = 0;
            }
        }
    }

    startNextWave() {
        this.currentWave++;
        let budget = this.baseBudget + (this.currentWave * 20);
        this.duration = 0;

        if (this.currentWave === 1) {
            enemiesObj.spawnEnemy(enemiesObj.types.snail);
        }

        const enemyOptions = Object.values(enemiesObj.types).filter(t => t.cost < 500);

        while (budget >= 5) {
            let possible = enemyOptions.filter(t => t.cost <= budget);
            if (possible.length === 0) break;
            let choice = possible[Math.floor(Math.random() * possible.length)];
            this.spawnQueue.push(choice);
            budget -= choice.cost;
        }

        this.spawnInterval = Math.max(10, 40 - (this.currentWave * 2));
        playerObj.hp = Math.min(playerObj.maxHP, playerObj.hp + 50);
    }
}

/* ============================
          BULLETS CLASS
   ============================ */
class Bullets {
    constructor() {
        this.types = {
            // Set parameters
            default: { width: 30, height: 8, speed: 20, damage: 7, color: "#1a1a1a" }
        };
        this.components = [];
    }
	// Spawn bullet with given parameters
    spawnBullet(posX, posY, vectorX, vectorY) {
        const type = this.types.default;
        const bullet = {
            x: posX, 
            y: posY,
            width: type.width,
            height: type.height,
            speedX: type.speed * vectorX,
            speedY: type.speed * vectorY,
			// calculate direction of the bullet
            angle: Math.atan2(vectorY, vectorX),
            damage: type.damage,
            color: type.color
        };
        this.components.push(bullet);
    }
	// ======== MATH ========
    update() {
        for (let i = this.components.length - 1; i >= 0; i--) {
            let b = this.components[i];
            // Move bullet
            b.x += b.speedX;
            b.y += b.speedY;
			
            // Destroy bullets outside the canvas
            if (b.x < -50 || b.x > gameArea.canvas.width + 50 || 
                b.y < -50 || b.y > gameArea.canvas.height + 50) {
                this.components.splice(i, 1);
            }
        }
    }
	// ======== VISUALS ========
    draw() {
    	// Draw bullet in the correct direction
        const ctx = gameArea.context;
        this.components.forEach(b => {
            ctx.save(); // Save the canvas state
            ctx.translate(b.x, b.y); // Move origin to the bullet
            ctx.rotate(b.angle); // Rotate the canvas
            
            ctx.fillStyle = b.color;
            // Center the rectangle so it rotates around its middle
            ctx.fillRect(-b.width / 2, -b.height / 2, b.width, b.height);
            
            ctx.restore(); // Restore canvas to normal
        });
    }
}

/* ============================
        GLOBAL VARIABLES
   ============================ */
let playerObj;
let enemiesObj = new Enemies();
let bulletsObj = new Bullets();
let waveManager = new WaveManager();
let keys = { w:false, a:false, s:false, d:false, ArrowLeft:false, ArrowUp:false, ArrowRight:false, ArrowDown:false };
let gameDuration = 0; // Store game duration in ticks
let isPaused = false; // Game is paused/unpaused

/* ============================
            START GAME
   ============================ */
function startGame() {
    alert("WASD to move, Arrow Keys to shoot, 'P' to Pause");
    playerObj = new Player(window.innerWidth / 2, window.innerHeight / 2);
    gameArea.start();
}

/* ============================
          GAME AREA ENGINE
   ============================ */
const gameArea = {
    canvas: document.createElement("canvas"),
    start: function() {
        this.canvas.width = window.innerWidth;
        this.canvas.height = window.innerHeight;
        this.context = this.canvas.getContext("2d");
        document.body.insertBefore(this.canvas, document.body.childNodes[0]);
        
        lastTimestamp = performance.now();
        requestAnimationFrame(engineLoop); 
    },
    clear: function() {
        this.context.clearRect(0, 0, this.canvas.width, this.canvas.height);
    }
};

/* ============================
       PLAYER MOVEMENT LOGIC
   ============================ */
function movePlayer() {
    playerObj.speedX = 0;
    playerObj.speedY = 0;
    if (keys.w && !keys.s) playerObj.speedY = -playerObj.speed;
    if (keys.s && !keys.w) playerObj.speedY = playerObj.speed;
    if (keys.a && !keys.d) playerObj.speedX = -playerObj.speed;
    if (keys.d && !keys.a) playerObj.speedX = playerObj.speed;
}

function calculateShots() {
    if (keys.ArrowRight) playerObj.shootRight();
    if (keys.ArrowLeft) playerObj.shootLeft();
    if (keys.ArrowUp) playerObj.shootUp();
    if (keys.ArrowDown) playerObj.shootDown();
}

function isColliding(a, b) {
    let aW = a.width || 0;
    let aH = a.height || 0;
    let bW = b.width || 0;
    let bH = b.height || 0;
    return !(a.x + aW < b.x || a.x > b.x + bW || a.y + aH < b.y || a.y > b.y + bH);
}

function checkCollisions() {
    // Loop through enemies
    for (let i = enemiesObj.components.length - 1; i >= 0; i--) {
        const enemy = enemiesObj.components[i];

        // ======== PLAYER + ENEMY ========
        if (isColliding(playerObj, enemy)) {
            if (enemy.special === "one_hp" && playerObj.hp != 1) {
                playerObj.hp = 1;
                playerObj.damageTickCounter = 0;
            } else {
                playerObj.takeDamage(enemy.damage);
            }
        }

        // ======== BULLET + ENEMY ========
        for (let j = bulletsObj.components.length - 1; j >= 0; j--) {
            const bullet = bulletsObj.components[j];
            // Since rectangular bullets are small, we can treat them as squares for isColliding
            const bBox = { x: bullet.x - 5, y: bullet.y - 5, width: 10, height: 10 };
            
            if (isColliding(bBox, enemy)) {
                enemy.hp -= bullet.damage; // Damage the enemy
                bulletsObj.components.splice(j, 1); // Remove the bullet
                
                // If enemy dies
                if (enemy.hp <= 0) {
                    enemiesObj.components.splice(i, 1);
                }
                break; // Stop checking this bullet
            }
        }
    }
}

/* ============================
            RESTART GAME
   ============================ */
function resetGame() {
    playerObj = null;
    enemiesObj = new Enemies();
    bulletsObj = new Bullets();
    waveManager = new WaveManager();
    gameDuration = 0;
    for (let k in keys) keys[k] = false;
    startGame();
}

/* ============================
              UPDATE
   ============================ */
function update() {
    if (isPaused) return true; // Don't process logic if paused

    movePlayer();
    
    playerObj.update();
    enemiesObj.update();
    bulletsObj.update();
    
    waveManager.update();
    
    calculateShots();
    checkCollisions();

    if (playerObj.hp <= 0) {
        // Draw the final frame immediately before the alert pauses everything
        renderGame(); 
        
        // Use a tiny timeout so the browser actually has a millisecond to 
        // paint the canvas before the alert blocks the thread
        const waveScore = waveManager.currentWave; 
        setTimeout(() => {
            alert("You Died!\nWaves Survived: " + (waveScore - 1));
            resetGame();
        }, 10);
        
        return false; // Return false to tell the engine to stop updating
    }
    
    // track the tick in the game clock
    gameDuration++;
    return true; // Keep going
}

/* ============================
          RENDER VISUALS
   ============================ */
function renderGame() {
    gameArea.clear();
    playerObj.draw();
    enemiesObj.draw();
    bulletsObj.draw();

    const ctx = gameArea.context;
    ctx.fillStyle = "black";
    ctx.font = "20px Arial";
    ctx.textAlign = "left";
    ctx.fillText("Wave: " + waveManager.currentWave, 20, 40);

    // ======== PAUSE OVERLAY ========
    if (isPaused) {
        ctx.fillStyle = "rgba(150,150,150,1)"; // Show gray screen so players don't cheat
        ctx.fillRect(0, 0, gameArea.canvas.width, gameArea.canvas.height);
        ctx.fillStyle = "white";
        ctx.font = "50px Arial";
        ctx.textAlign = "center";
        ctx.fillText("PAUSED", gameArea.canvas.width / 2, gameArea.canvas.height / 2);
        
        ctx.font = "18px Arial";
        ctx.fillText("Press P or Esc to unpause", gameArea.canvas.width / 2, gameArea.canvas.height / 2 + 40);
    }
}

/* ============================
              ENGINE LOOP
   ============================ */
function engineLoop(currentTime) {
    let deltaTime = currentTime - lastTimestamp;
    lastTimestamp = currentTime;

    frameAccumulator += deltaTime;

    // We still want to run the loop so that the renderGame can catch the "unpause" state
    let running = true;
    while (frameAccumulator >= tickLength) {
        running = update(); 
        frameAccumulator -= tickLength;
        if (!running) break; // Stop ticking if player died
    }

    if (running) {
        renderGame();
        requestAnimationFrame(engineLoop);
    }
}

/* ============================
        KEYBOARD LISTENERS
   ============================ */
document.addEventListener("keydown", e => { 
    if (keys.hasOwnProperty(e.key)) keys[e.key] = true; 
    
    // Toggle Pause with 'p' or 'Escape'
    if (e.key.toLowerCase() === 'p' || e.key === 'Escape') {
        isPaused = !isPaused;
    }
});
document.addEventListener("keyup", e => { if (keys.hasOwnProperty(e.key)) keys[e.key] = false; });

</script>
</body>
</html>
